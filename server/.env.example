PORT=5000
# Include your database name in the URI path (example database: inventory)
# mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/inventory?retryWrites=true&w=majority
MONGO_URI=your_mongodb_connection_string_with_database_name
JWT_SECRET=your_jwt_secret_key
DEMO_USERNAME=demo
DEMO_PASSWORD=demo123

# Set this to your Netlify site URL (e.g. https://inventory-app.netlify.app)
FRONTEND_URL=

# Optional: additional allowed origin if needed
NETLIFY_URL=
